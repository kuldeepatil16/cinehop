{
  "name": "cinehop",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev": "next dev",
    "dev:clean": "npm run clean && next dev",
    "build": "next build",
    "build:clean": "npm run clean && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "scrape": "npx tsx scrapers/index.ts",
    "scrape:cinesa": "npx tsx scrapers/cinesa.ts",
    "scrape:yelmo": "npx tsx scrapers/yelmo.ts",
    "scrape:kinepolis": "npx tsx scrapers/kinepolis.ts",
    "enrich": "npx tsx scrapers/enrich-posters.ts",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.44.0",
    "@supabase/supabase-js": "^2.57.4",
    "@vercel/analytics": "^1.5.0",
    "clsx": "^2.1.1",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.21",
    "playwright": "^1.55.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
